1. Identify production issues without manually checking large log files.
tail -f /var/log/app.log | grep "ERROR"

2. Monitor disk usage and trigger alerts if it exceeds a threshold.
df -h | grep "/dev/xvda1"

3. Backup
tar -czf backup.tar.gz /data

3.1 Restore
tar -xzf backup/backup_29042025_pre_daily_backup.tar.gz -c /home/ec2user/restore

4. to check running processes and troubleshoot application issues.
ps -ef | grep java

5. Bash scripts in deployment pipelines to pull latest code, install dependencies, and restart services.
#!/bin/bash
git pull origin main
npm install
pm2 restart app

top            - CPU usage, memory usage
df -h          - disk file system
free -m        - RAM usage
ps -ef         - Process status PID
netstat -tulnp - network ports & services
chmod          - change file permission

6. find /release/may/log -type f -mtime +21 -delete

7. mkdir foldername - folder creation
   rmdir foldername - empty deletion
   rm -rf /path/to/folder
   rm -rf /path/to/folder/* - delete files inside the folder
   rm -ri /path/to/folder/* - delete files inside the folder - The -i option asks for confirmation before each deletion.

8. awk '{print $1}' /var/log/httpd/access.log | sort | uniq | wc -l
9. grep -i "ERROR" /tmp/app.log | tee error_log.txt | wc -l
10. find /var/log/myapp/ -name "*.log" -size +5M -exec rm -f {} \;




