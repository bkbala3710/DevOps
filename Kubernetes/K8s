apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend-httpd-deployment
  namespace: dev
spec:
  strategy:
    type: Recreate
  replicas: 4
  selector:
    matchLabels:
      app: frontend-httpd
  template:
    metadata:
      labels:
        app: frontend-httpd
    spec:
      containers:
      - name: httpd-container
        image: httpd:latest
        ports:
        - containerPort: 80
---
apiVersion: v1
kind: Service
metadata:
  name: frontend-httpd-nodeport-svc
  namespace: dev
spec:
  type: NodePort
  selector:
    app: frontend-httpd
  ports:
    - port: 80
      targetPort: 80
      nodePort: 30001
-------------------------------------------------------
apiVersion: v1
kind: Pod
metadata:
  name: pod1
  labels:
    colour: black
spec:
  containers:
  - name: cont1
    image: httpd
    ports:
    - containerPort: 80
---
apiVersion: v1
kind: Pod
metadata:
  name: pod2
